{
  "name": "@sumup/vendure-plugin",
  "version": "0.1.0",
  "description": "SumUp payment plugin for Vendure.",
  "author": "SumUp <support@sumup.com> (https://sumup.com/)",
  "license": "Apache-2.0",
  "type": "commonjs",
  "homepage": "https://github.com/sumup/sumup/tree/main/sumup-plugin-vendure",
  "bugs": {
    "url": "https://github.com/sumup/sumup/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sumup/sumup.git",
    "directory": "sumup-plugin-vendure"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "keywords": [
    "vendure",
    "vendure-plugin",
    "sumup",
    "payments",
    "checkout",
    "ecommerce"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run lint && npm run typecheck && npm run build && npm run pack:dry-run",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@sumup/sdk": "0.1.6"
  },
  "peerDependencies": {
    "@vendure/core": "^3.6.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@vendure/core": "3.7.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
