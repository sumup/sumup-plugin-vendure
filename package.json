{
  "name": "@sumup/vendure-plugin",
  "version": "0.1.0",
  "description": "SumUp payment plugin for Vendure.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "vendure",
    "vendure-plugin",
    "sumup",
    "payments"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run lint && npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@sumup/sdk": "0.1.6"
  },
  "peerDependencies": {
    "@vendure/core": "^3.6.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/express": "5.0.6",
    "@types/node": "25.9.2",
    "@vendure/core": "3.6.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
